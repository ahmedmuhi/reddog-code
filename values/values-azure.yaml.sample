# Red Dog - Azure Cloud Overrides (Sample)
# Demonstrates RabbitMQ + Cosmos DB via metadata overrides (see ADR-0013).
# Chart defaults: charts/reddog/values.yaml, charts/infrastructure/values.yaml

global:
  environment: azure
  domain: reddog.contoso.cloud

dapr:
  pubsub:
    type: rabbitmq
    metadata:
      - name: host
        secretKeyRef:
          name: rabbitmq-shared-credentials
          key: amqp-uri
      - name: durable
        value: "true"

  stateStore:
    type: azure.cosmosdb
    metadata:
      - name: url
        value: https://reddog.documents.azure.com:443/
      - name: masterKey
        secretKeyRef:
          name: cosmos-account-key
          key: master-key
      - name: database
        value: reddog
      - name: collection
        value: state

  secretStore:
    type: azure.keyvault
    metadata:
      - name: vaultName
        value: reddog-kv
      - name: azureTenantId
        secretKeyRef:
          name: workload-identity
          key: tenant-id
      - name: azureClientId
        secretKeyRef:
          name: workload-identity
          key: client-id

# Ingress: cloud domain with TLS
ingress:
  tls:
    enabled: true
  annotations:
    nginx.ingress.kubernetes.io/use-regex: "true"
    nginx.ingress.kubernetes.io/rewrite-target: /$2
  hosts:
    - host: reddog.contoso.cloud
      paths:
        - path: /api/orders(/|$)(.*)
          pathType: ImplementationSpecific
          service: orderservice
          port: 80
        - path: /api/makeline(/|$)(.*)
          pathType: ImplementationSpecific
          service: makelineservice
          port: 80
        - path: /api/accounting(/|$)(.*)
          pathType: ImplementationSpecific
          service: accountingservice
          port: 80
        - path: /()(.*)
          pathType: ImplementationSpecific
          service: ui
          port: 80

# Cloud infrastructure (managed services — disable local infra)
infrastructure:
  redis:
    enabled: false
  sqlserver:
    enabled: false

# Binding overrides for cloud storage
services:
  receiptgenerationservice:
    binding:
      enabled: true
      metadata:
        - name: storageAccount
          value: reddogreceipts
        - name: container
          value: receipts
        - name: accountKey
          secretKeyRef:
            name: receipts-storage-key
            key: key1

  virtualworker:
    binding:
      metadata:
        - name: schedule
          value: "0 */5 * * * *"  # Every 5 minutes in production

  ui:
    env:
      VITE_MAKELINE_BASE_URL: https://reddog.contoso.cloud/api/makeline
      VITE_ACCOUNTING_BASE_URL: https://reddog.contoso.cloud/api/accounting
